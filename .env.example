# Environment Variables for H2O Quote RPA
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control!

# ============================================================================
# EMAIL CREDENTIALS
# ============================================================================
EMAIL_USERNAME=your-email@example.com
EMAIL_PASSWORD=your-app-password-here
EMAIL_FROM=quotes@h2oins.com
EMAIL_REPLY_TO=quotes@h2oins.com

# ============================================================================
# DATABASE (if used in future)
# ============================================================================
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=h2o_quotes
# DB_USER=admin
# DB_PASSWORD=password

# ============================================================================
# API KEYS (if needed)
# ============================================================================
# OPENAI_API_KEY=sk-...
# TWILIO_API_KEY=...

# ============================================================================
# MISC
# ============================================================================
ENVIRONMENT=development  # development, staging, production
DEBUG=True

# ============================================================================
# GOOGLE DRIVE
# ============================================================================
# Folder where client folders will be created
DRIVE_MAIN_FOLDER_ID=

# Optional explicit user for Domain-Wide Delegation impersonation.
# Recommended: a real Google Workspace user with Drive access.
# If empty, the code tries EMAIL_USERNAME and then EMAIL_FROM.
DRIVE_IMPERSONATE_USER=

# If impersonation fails, allow fallback to raw Service Account auth.
# Keep True only when DRIVE_MAIN_FOLDER_ID points to a Shared Drive folder.
DRIVE_ALLOW_SERVICE_ACCOUNT_FALLBACK=True
