# .gitignore for H2O Quote RPA

# Environment variables (NEVER commit!)


# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log

# Temporary files
*.tmp
test_output.txt
matching_results.txt
results_display.txt

# Excel temporary files
~$*.xlsx
~$*.xlsb
~$*.xls

# Data (if sensitive)
# Uncomment if you don't want to commit PDFs/JSONs
# data/input/*.pdf
# data/output/*.json

# Testing
.pytest_cache/
.coverage
htmlcov/

# Service Account Credentials
config/*.json
