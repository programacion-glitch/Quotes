# Environment Variables for H2O Quote RPA
# NEVER commit .env to version control!

# ============================================================================
# EMAIL CREDENTIALS
# ============================================================================

# TESTING: Uncomment to override recipient (all emails go to this address)
# Leave commented for production (emails go to original sender)
TEST_EMAIL_OVERRIDE=programacion@h2oins.com

# DRY RUN: Set to True to simulate workflow without actually sending emails
DRY_RUN=False

# ============================================================================
# MISC
# ============================================================================
ENVIRONMENT=development
DEBUG=True

# ============================================================================
# GOOGLE DRIVE SETTINGS
# ============================================================================
# ID of the main folder where client folders will be created
DRIVE_MAIN_FOLDER_ID=0ALmdSjy0qv6gUk9PVA

# Optional explicit user for Domain-Wide Delegation impersonation.
# Recommended: a real Google Workspace user with Drive access.
# If empty, the code tries EMAIL_USERNAME and then EMAIL_FROM.
DRIVE_IMPERSONATE_USER=programacion@h20ins.com

# If impersonation fails, allow fallback to raw Service Account auth.
# Keep True only when DRIVE_MAIN_FOLDER_ID points to a Shared Drive folder.
DRIVE_ALLOW_SERVICE_ACCOUNT_FALLBACK=True